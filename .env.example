# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Stripe API keys (get from https://dashboard.stripe.com/apikeys)
# Use test keys (sk_test_...) until you're ready to accept real money.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret — only needed for the stripe-webhook function.
# Get this when you create the webhook endpoint in Stripe Dashboard → Developers → Webhooks.
# Locally, the netlify CLI will print one when you run `stripe listen --forward-to ...`.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Public site URL — used by the function to build success/cancel redirects.
# In local dev with `netlify dev`, this is typically http://localhost:8888
# In production, set to your real domain (e.g. https://adamnoteve.com)
SITE_URL=http://localhost:8888

# Stripe coupon ID for the HEARTBROKEN promo code (created in Stripe Dashboard
# → Products → Coupons). Looks like `5ABcdEFG`. Leave blank to disable.
STRIPE_COUPON_HEARTBROKEN=

# ============================================================
# Printful (fulfillment) — optional but recommended for POD merch
# ============================================================
# Get from https://www.printful.com/dashboard/store -> API
# If unset, the webhook will skip Printful and just log the order.
PRINTFUL_API_KEY=

# Set to "true" to auto-confirm orders for production (Printful starts printing
# immediately and charges your Printful balance). Leave unset/false during
# testing to create draft orders you can review/confirm in the Printful UI.
PRINTFUL_AUTO_CONFIRM=false

# ============================================================
# Resend (transactional email) — optional but recommended
# ============================================================
# Get from https://resend.com → API Keys. Free tier: 100 emails/day.
# If unset, the webhook skips email send (Stripe still sends its own basic receipt).
RESEND_API_KEY=

# Verified sender. Format: "Brand Name <orders@yourdomain.com>". The domain MUST
# be verified in Resend → Domains, otherwise emails will fail to send.
EMAIL_FROM=Adamnoteve <orders@yourdomain.com>

# Where customers should reply for support. Used as Reply-To on the email and
# shown in the body. If unset, falls back to EMAIL_FROM.
EMAIL_SUPPORT=support@yourdomain.com

# ============================================================
# Stripe Tax — optional, requires Dashboard setup
# ============================================================
# Set to "true" once you have:
#   1. Enabled Stripe Tax in Dashboard → Tax → Settings
#   2. Registered for sales tax in your home state(s)
#   3. Confirmed your origin address in Stripe
# Stripe will then automatically calculate tax at checkout based on the
# customer's shipping address and remit it correctly.
STRIPE_TAX_ENABLED=false
